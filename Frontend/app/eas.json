{
  "cli": { "version": ">= 16.32.0", "appVersionSource": "remote" },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "NODE_VERSION": "20",
        "NPM_CONFIG_LEGACY_PEER_DEPS": "1",
        "EXPO_PUBLIC_API_URL": "http://13.127.14.35:5000/api"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "NODE_VERSION": "20",
        "NPM_CONFIG_LEGACY_PEER_DEPS": "1",
        "EXPO_PUBLIC_API_URL": "http://13.127.14.35:5000/api"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "autoIncrement": true,

      "env": {
        "NODE_VERSION": "20",
        "NPM_CONFIG_LEGACY_PEER_DEPS": "1",
        "EXPO_PUBLIC_API_URL": "http://13.127.14.35:5000/api"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "track": "production"
      }
    }
  }
}
