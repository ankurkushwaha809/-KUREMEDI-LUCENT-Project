{
  "name": "lucent-app",
  "version": "1.0.0",
  "description": "E-commerce application with mobile app, admin dashboard, marketing app, and website",
  "private": true,
  "workspaces": [
    "backend",
    "Frontend/app",
    "Frontend/admin",
